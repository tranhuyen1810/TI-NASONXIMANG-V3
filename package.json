{
  "name": "ti-nasonximang-v3",
  "version": "1.0.0",
  "description": "Desktop app quan ly nhap don hang khach hang",
  "main": "dist-electron/electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build:electron && concurrently -n VITE,TSC,ELECTRON -c cyan,magenta,yellow \"vite\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron dist-electron/electron/main.js\"",
    "build": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "vercel-build": "vite build",
    "production": "tsc -p tsconfig.electron.prod.json && vite build && electron-builder --win --x64 --publish never",
    "release:win": "tsc -p tsconfig.electron.prod.json && vite build && electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.tinasonximang.orderapp",
    "productName": "TI-NASONXIMANG",
    "directories": {
      "output": "dist-electron-build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tranhuyen1810",
        "repo": "TI-NASONXIMANG-V3"
      }
    ]
  }
}
